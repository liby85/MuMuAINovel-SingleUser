# ==========================================
# MuMuAINovel-SingleUser 配置文件示例
# ==========================================
# 单用户版本 - 无需认证，使用 SQLite
# 复制此文件为 .env 并修改配置值
# cp .env.example .env

# ==========================================
# 应用配置
# ==========================================
APP_NAME=MuMuAINovel-SingleUser
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ==========================================
# SQLite 数据库配置（单用户模式）
# ==========================================
DATABASE_URL=sqlite+aiosqlite:///data/mumuai.db

# ==========================================
# AI 服务配置（至少配置一个）
# ==========================================
# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# 默认 AI 配置
DEFAULT_AI_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=32000

# ==========================================
# 单用户模式配置
# ==========================================
LOCAL_AUTH_ENABLED=false

# ==========================================
# 提示词工坊配置
# ==========================================
WORKSHOP_MODE=client
WORKSHOP_CLOUD_URL=https://mumuverse.space:1566
WORKSHOP_API_TIMEOUT=30